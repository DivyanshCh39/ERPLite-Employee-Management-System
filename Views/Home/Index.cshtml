@{
    ViewData["Title"] = "Dashboard";
}

<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="card stat-card blue p-3">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <small class="text-muted fw-semibold">TOTAL EMPLOYEES</small>
                    <h2 class="fw-bold mb-0">@ViewBag.TotalEmployees</h2>
                </div>
                <i class="bi bi-people fs-1 text-primary opacity-50"></i>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card green p-3">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <small class="text-muted fw-semibold">ACTIVE EMPLOYEES</small>
                    <h2 class="fw-bold mb-0">@ViewBag.ActiveEmployees</h2>
                </div>
                <i class="bi bi-person-check fs-1 text-success opacity-50"></i>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card orange p-3">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <small class="text-muted fw-semibold">DEPARTMENTS</small>
                    <h2 class="fw-bold mb-0">@ViewBag.TotalDepartments</h2>
                </div>
                <i class="bi bi-diagram-3 fs-1 text-warning opacity-50"></i>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card purple p-3">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <small class="text-muted fw-semibold">MONTHLY SALARY BILL</small>
                    <h2 class="fw-bold mb-0">₹@String.Format("{0:N0}", ViewBag.TotalSalaryBill)</h2>
                </div>
                <i class="bi bi-currency-rupee fs-1 text-purple opacity-50" style="color:#6a1b9a"></i>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header bg-white border-0 py-3 d-flex justify-content-between align-items-center">
        <h6 class="mb-0 fw-bold">Recent Joiners</h6>
        <a href="/Employee/Index" class="btn btn-sm btn-primary">View All</a>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th class="ps-4">Name</th>
                    <th>Designation</th>
                    <th>Department</th>
                    <th>Joining Date</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var emp in ViewBag.RecentEmployees)
                {
                    <tr>
                        <td class="ps-4 fw-semibold">@emp.FullName</td>
                        <td>@emp.Designation</td>
                        <td><span class="badge bg-primary-subtle text-primary">@emp.Name</span></td>
                        <td>@emp.JoiningDate.ToString("dd MMM yyyy")</td>
                    </tr>
                }
                @if (((IEnumerable<dynamic>)ViewBag.RecentEmployees).Count() == 0)
                {
                    <tr><td colspan="4" class="text-center text-muted py-4">No employees added yet</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
