@model Department
@{
    ViewData["Title"] = "Delete Department";
}

<div class="row justify-content-center">
    <div class="col-lg-5">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white py-3">
                <h6 class="mb-0 fw-bold"><i class="bi bi-exclamation-triangle me-2"></i>Confirm Delete</h6>
            </div>
            <div class="card-body text-center py-4">
                <div class="rounded-circle bg-danger-subtle d-inline-flex align-items-center justify-content-center fw-bold mb-3"
                     style="width:64px;height:64px;font-size:1.5rem;">
                    @Model.Name[0]
                </div>
                <h5 class="fw-bold">@Model.Name</h5>
                <p class="text-muted small">@(Model.Description ?? "No description")</p>

                @if (Model.Employees.Any())
                {
                    <div class="alert alert-danger text-start">
                        <i class="bi bi-shield-exclamation me-2"></i>
                        Cannot delete — this department has <strong>@Model.Employees.Count employee(s)</strong>.
                        Reassign them first.
                    </div>
                    <a href="/Department/Index" class="btn btn-outline-secondary">Go Back</a>
                }
                else
                {
                    <div class="alert alert-warning text-start">
                        <i class="bi bi-info-circle me-2"></i>
                        This action is <strong>permanent</strong> and cannot be undone.
                    </div>
                    <form asp-action="Delete" method="post" class="d-flex gap-3 justify-content-center">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />
                        <button type="submit" class="btn btn-danger px-4">
                            <i class="bi bi-trash me-1"></i> Yes, Delete
                        </button>
                        <a href="/Department/Index" class="btn btn-outline-secondary px-4">Cancel</a>
                    </form>
                }
            </div>
        </div>
    </div>
</div>
