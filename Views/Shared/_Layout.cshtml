<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ERPLite</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet" />
    <style>
        body { background: #f0f2f5; }
        .sidebar {
            width: 240px; min-height: 100vh;
            background: #1a237e; position: fixed; top: 0; left: 0;
        }
        .sidebar .brand {
            padding: 20px; color: #fff;
            font-size: 1.2rem; font-weight: 700;
            border-bottom: 1px solid rgba(255,255,255,0.15);
        }
        .sidebar .nav-link {
            color: rgba(255,255,255,0.75); padding: 10px 20px;
            border-radius: 0; transition: background 0.2s;
        }
        .sidebar .nav-link:hover, .sidebar .nav-link.active {
            background: rgba(255,255,255,0.15); color: #fff;
        }
        .sidebar .nav-link i { margin-right: 8px; }
        .main-content { margin-left: 240px; padding: 24px; }
        .topbar {
            background: #fff; padding: 12px 24px;
            border-bottom: 1px solid #dee2e6;
            margin: -24px -24px 24px -24px;
            display: flex; justify-content: space-between; align-items: center;
        }
        .card { border: none; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.07); }
        .stat-card { border-left: 4px solid; }
        .stat-card.blue  { border-color: #1565c0; }
        .stat-card.green { border-color: #2e7d32; }
        .stat-card.orange { border-color: #e65100; }
        .stat-card.purple { border-color: #6a1b9a; }
        .table th { background: #f8f9fa; font-weight: 600; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.04em; }
    </style>
</head>
<body>

<!-- Sidebar -->
<div class="sidebar d-flex flex-column">
    <div class="brand">
        <i class="bi bi-building"></i> ERPLite
    </div>
    <nav class="nav flex-column mt-2">
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
           href="/Home/Index">
            <i class="bi bi-speedometer2"></i> Dashboard
        </a>
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Employee" ? "active" : "")"
           href="/Employee/Index">
            <i class="bi bi-people"></i> Employees
        </a>
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Department" ? "active" : "")"
           href="/Department/Index">
            <i class="bi bi-diagram-3"></i> Departments
        </a>
        <a class="nav-link" href="/Employee/Report">
            <i class="bi bi-bar-chart-line"></i> Salary Report
        </a>
    </nav>
    <div class="mt-auto p-3">
        <small class="text-white-50">Logged in as</small><br/>
        <strong class="text-white">@User.Identity?.Name</strong>
    </div>
</div>

<!-- Main content -->
<div class="main-content">
    <div class="topbar">
        <h5 class="mb-0 fw-bold text-dark">@ViewData["Title"]</h5>
        <form asp-controller="Account" asp-action="Logout" method="post" class="mb-0">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-sm btn-outline-danger">
                <i class="bi bi-box-arrow-right"></i> Logout
            </button>
        </form>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @RenderBody()
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
