@model Employee
@{
    ViewData["Title"] = "Employee Details";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header bg-white border-0 py-3 d-flex justify-content-between align-items-center">
                <h6 class="mb-0 fw-bold"><i class="bi bi-person-badge me-2 text-info"></i>Employee Profile</h6>
                @if (Model.IsActive)
                {
                    <span class="badge bg-success">Active</span>
                }
                else
                {
                    <span class="badge bg-secondary">Inactive</span>
                }
            </div>
            <div class="card-body">
                <!-- Avatar + Name -->
                <div class="text-center mb-4">
                    <div class="rounded-circle bg-primary d-inline-flex align-items-center justify-content-center text-white fw-bold"
                         style="width:80px;height:80px;font-size:2rem;">
                        @Model.FirstName[0]@Model.LastName[0]
                    </div>
                    <h4 class="fw-bold mt-3 mb-0">@Model.FullName</h4>
                    <p class="text-muted mb-0">@Model.Designation</p>
                    <span class="badge bg-primary-subtle text-primary mt-1">@Model.Department?.Name</span>
                </div>

                <hr />

                <div class="row g-3">
                    <div class="col-6">
                        <small class="text-muted d-block">Email</small>
                        <span class="fw-semibold">@Model.Email</span>
                    </div>
                    <div class="col-6">
                        <small class="text-muted d-block">Phone</small>
                        <span class="fw-semibold">@Model.PhoneNumber</span>
                    </div>
                    <div class="col-6">
                        <small class="text-muted d-block">Salary</small>
                        <span class="fw-semibold text-success">₹@Model.Salary.ToString("N0")</span>
                    </div>
                    <div class="col-6">
                        <small class="text-muted d-block">Joining Date</small>
                        <span class="fw-semibold">@Model.JoiningDate.ToString("dd MMM yyyy")</span>
                    </div>
                    <div class="col-6">
                        <small class="text-muted d-block">Employee ID</small>
                        <span class="fw-semibold">#EMP-@Model.Id.ToString("D4")</span>
                    </div>
                    <div class="col-6">
                        <small class="text-muted d-block">Experience</small>
                        @{
                            var exp = (DateTime.Today - Model.JoiningDate).Days / 365;
                            var months = ((DateTime.Today - Model.JoiningDate).Days % 365) / 30;
                        }
                        <span class="fw-semibold">@exp yr @months mo</span>
                    </div>
                </div>

                <hr class="mt-4" />
                <div class="d-flex gap-2">
                    <a href="/Employee/Edit/@Model.Id" class="btn btn-warning">
                        <i class="bi bi-pencil me-1"></i> Edit
                    </a>
                    <a href="/Employee/Delete/@Model.Id" class="btn btn-outline-danger">
                        <i class="bi bi-trash me-1"></i> Delete
                    </a>
                    <a href="/Employee/Index" class="btn btn-outline-secondary ms-auto">
                        <i class="bi bi-arrow-left me-1"></i> Back
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
